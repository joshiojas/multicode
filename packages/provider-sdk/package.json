{
  "name": "@multicode/provider-sdk",
  "version": "0.1.0",
  "description": "The stable provider adapter contract, capability negotiation, registry/loader, and shared conformance suite for Multicode providers.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./conformance": {
      "types": "./dist/conformance/index.d.ts",
      "import": "./dist/conformance/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "main": "./dist/index.js",
