{
  "name": "multicode-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Multicode — a model-agnostic MCP server for delegating software-engineering tasks to external coding agents.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean && rimraf \"packages/**/dist\" \"packages/**/*.tsbuildinfo\"",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "multicode": "node packages/cli/dist/bin/multicode.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
